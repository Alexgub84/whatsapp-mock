  "dependencies": {
    "lucide-react": "0.469.0"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "^4.2.4",
    "typescript": "5.7.2",
    "vite": "6.0.5",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
