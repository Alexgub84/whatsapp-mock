{
  "name": "@alexgub84/whatsapp-chat-mock",
  "version": "1.1.0",
  "type": "module",
  "description": "A WhatsApp-style animated chat UI component for React",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
